# GLIA Dashboard Configuration
# v1.4.5+

# The URL where the GLIA backend is running (default: http://localhost:3001)
VITE_BACKEND_URL=http://localhost:3001

# The secret key required by the backend (X-GLIA-Secret)
# If the backend was installed via install.sh/bat, this was auto-generated in backend/.env
VITE_GLIA_SECRET=
