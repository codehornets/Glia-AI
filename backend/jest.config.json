{
  "testEnvironment": "node",
  "roots": ["<rootDir>/src", "<rootDir>/tests"],
  "moduleFileExtensions": ["ts", "js"],
  "transform": {
    "^.+\\.ts$": ["ts-jest", { "tsconfig": "tsconfig.test.json" }]
  },
  "collectCoverageFrom": [
    "src/utils/**/*.ts",
    "src/services/**/*.ts"
  ],
  "transformIgnorePatterns": [
    "node_modules/(?!(uuid)/)"
  ],
  "moduleNameMapper": {
    "^uuid$": "uuid"
  }
}