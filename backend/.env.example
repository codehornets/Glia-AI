PORT=3001

# Neo4j (Docker)
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=synqpassword123

# MongoDB (Docker)
MONGO_URI=mongodb://synq:synqpassword123@localhost:27018/synqdb?authSource=admin

# Groq — free at console.groq.com (no credit card required)
GROQ_API_KEY=gsk_your_key_here

# ChromaDB (Docker)
CHROMA_URL=http://localhost:8000

# Ollama (local — install from ollama.com, run: ollama pull nomic-embed-text)
OLLAMA_URL=http://localhost:11434

# Set to "true" to enable verbose debug logging
DEBUG=false

# Backend for Graph Extraction: "ollama" (local) or "groq" (cloud)
GRAPH_BACKEND=groq

# Ollama model to use for extraction (e.g. llama3.1:8b, phi3.5, qwen2.5:1.5b)
OLLAMA_MODEL=llama3.1:8b

# Optional: shared secret for request auth between extension/dashboard and backend.
# When set, all API requests must include header: X-SYNQ-Secret: <value>
# Generate a random value: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Leave blank to run without auth (fine for local dev on a trusted machine).
SYNQ_SECRET=
