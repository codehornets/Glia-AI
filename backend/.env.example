PORT=3001

# Neo4j (Docker)
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=gliapassword123

# MongoDB (Docker)
MONGO_URI=mongodb://glia:gliapassword123@localhost:27018/gliadb?authSource=admin

# Groq — free at console.groq.com (no credit card required)
GROQ_API_KEY=gsk_your_key_here

# ChromaDB (Docker)
CHROMA_URL=http://localhost:8000

# Ollama (local — install from ollama.com, run: ollama pull nomic-embed-text)
OLLAMA_URL=http://localhost:11434

# Set to "debug" to enable verbose debug logging (HyDE queries, embeddings, etc.)
LOG_LEVEL=info

# Backend for Graph Extraction: "ollama" (local) or "groq" (cloud)
GRAPH_BACKEND=groq

# Storage Mode: "docker" (Chroma/Mongo/Neo4j) or "sqlite" (Zero-Docker)
GLIA_STORAGE_MODE=sqlite

# Optional: Custom path for SQLite database
# SQLITE_DB_PATH=./glia.db

# Ollama model to use for extraction (e.g. llama3.1:8b, phi3.5, qwen2.5:1.5b)
OLLAMA_MODEL=llama3.1:8b

